# ==================== MULTI-LLM CONFIGURATION ====================
# GENIE uses 5 LLM providers for consensus-based decisions

# OpenAI (Required - Primary provider)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# Anthropic Claude (Recommended - Backup provider)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-1-20250805

# Google Gemini (Recommended - Backup provider)
GOOGLE_API_KEY=your-google-gemini-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# Mistral AI (Optional - Additional provider)
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-large-latest

# AI21 Labs (Optional - Additional provider)
AI21_API_KEY=your-ai21-api-key-here
AI21_MODEL=jambachat

# ==================== SYSTEM CONFIGURATION ====================

# Workflow Control
MAX_ITERATIONS=5
RETRY_ATTEMPTS=3
REQUEST_TIMEOUT=60000

# Project Generation
PROJECTS_PATH=./projects

# Environment
NODE_ENV=development

# ==================== DEPARTMENT DEFAULTS ====================
# These are overridden per-department based on function

# Finance/Accounting (0.05 - very precise)
FINANCE_TEMPERATURE=0.05

# Marketing (0.3 - creative)
MARKETING_TEMPERATURE=0.3

# Engineering (0.1 - technical precision)
ENGINEERING_TEMPERATURE=0.1

# ==================== XRPL DKP BOT (OPTIONAL) ====================
# Start in DRY_RUN=true, verify behavior, then switch to false for live orders.

XRPL_WS_URL=wss://s1.ripple.com
XRPL_SECRET=sEdYourWalletSecret
XRPL_ACCOUNT=rYourWalletAddress

DKP_CURRENCY=DKP
DKP_ISSUER=rIssuerAddressForDKP

# Per-loop budget and safety controls
DKP_BOT_SPEND_XRP_PER_ORDER=1
DKP_BOT_MAX_OPEN_ORDERS=3
DKP_BOT_MAX_DAILY_SPEND_XRP=10
DKP_BOT_MIN_XRP_BUFFER=30

# Pricing controls (in basis points)
# BUY_DISCOUNT_BPS=100 means place bid 1% below current best ask
DKP_BOT_BUY_DISCOUNT_BPS=100
# Optional sell/take-profit behavior
DKP_BOT_ENABLE_SELLS=false
DKP_BOT_TAKE_PROFIT_BPS=500
DKP_BOT_SELL_FRACTION=0.1

# Runtime
DKP_BOT_LOOP_SECONDS=60
DKP_BOT_DRY_RUN=true
DKP_BOT_STATE_FILE=.dkp-bot-state.json
